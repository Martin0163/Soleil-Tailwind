<section class="w-full py-16 bg-soleil-cream">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12">

    {% if section.settings.title != blank %}
      <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-10 text-center">
        {{ section.settings.title }}
      </h2>
    {% endif %}

    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 items-center justify-items-center">

      {% if section.settings.logo_stripe != blank %}
        <img 
          src="{{ section.settings.logo_stripe | image_url: width: 300 }}"
          alt="Stripe"
          class="h-10 w-auto object-contain opacity-80 hover:opacity-100 transition"
        >
      {% endif %}

      {% if section.settings.logo_paypal != blank %}
        <img 
          src="{{ section.settings.logo_paypal | image_url: width: 300 }}"
          alt="PayPal"
          class="h-10 w-auto object-contain opacity-80 hover:opacity-100 transition"
        >
      {% endif %}

      {% if section.settings.logo_cards != blank %}
        <img 
          src="{{ section.settings.logo_cards | image_url: width: 300 }}"
          alt="Tarjetas de crédito y débito"
          class="h-10 w-auto object-contain opacity-80 hover:opacity-100 transition"
        >
      {% endif %}

      {% if section.settings.logo_kueski != blank %}
        <img 
          src="{{ section.settings.logo_kueski | image_url: width: 300 }}"
          alt="Kueski Pay"
          class="h-10 w-auto object-contain opacity-80 hover:opacity-100 transition"
        >
      {% endif %}

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Métodos de pago",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Métodos de pago"
    },
    {
      "type": "image_picker",
      "id": "logo_stripe",
      "label": "Logo Stripe"
    },
    {
      "type": "image_picker",
      "id": "logo_paypal",
      "label": "Logo PayPal"
    },
    {
      "type": "image_picker",
      "id": "logo_cards",
      "label": "Logo Tarjetas (Visa, Mastercard, etc.)"
    },
    {
      "type": "image_picker",
      "id": "logo_kueski",
      "label": "Logo Kueski Pay"
    }
  ],
  "presets": [
    {
      "name": "Métodos de pago"
    }
  ]
}
{% endschema %}
