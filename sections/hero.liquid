<section 
  class="hero"
  data-section-id="{{ section.id }}"
  data-section-type="hero"
>
  <div class="hero__background">
    {%- if section.settings.image != blank -%}
      <img 
        src="{{ section.settings.image | image_url: width: 1920 }}" 
        alt="{{ section.settings.image.alt | default: section.settings.heading }}"
        class="hero__image"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      <img 
        src="https://images.unsplash.com/photo-1672794776762-18dddc72982e?w=1920&q=80" 
        alt="{{ section.settings.heading }}"
        class="hero__image"
        loading="eager"
      >
    {%- endif -%}
    <div class="hero__overlay"></div>
  </div>
  
  <div class="hero__container">
    <div class="hero__content" data-animate="fadeInUp">
      {%- if section.settings.badge_text != blank -%}
        <span class="hero__badge">
          {% render 'icon-sparkles' %}
          {{ section.settings.badge_text }}
        </span>
      {%- endif -%}
      
      <h1 class="hero__title">
        {{ section.settings.heading }}
        {%- if section.settings.heading_highlight != blank -%}
          <br>
          <span class="text-gold-gradient">{{ section.settings.heading_highlight }}</span>
        {%- endif -%}
      </h1>
      
      {%- if section.settings.description != blank -%}
        <p class="hero__description">{{ section.settings.description }}</p>
      {%- endif -%}
      
      <div class="hero__buttons">
        {%- if section.settings.button_text != blank -%}
          <a href="{{ section.settings.button_link }}" class="btn btn--primary">
            {{ section.settings.button_text }}
            {% render 'icon-arrow-right' %}
          </a>
        {%- endif -%}
        
        {%- if section.settings.button_secondary_text != blank -%}
          <a href="{{ section.settings.button_secondary_link }}" class="btn btn--secondary">
            {{ section.settings.button_secondary_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
  }

  .hero__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, 
      rgba(255, 255, 255, 0.9) 0%, 
      rgba(255, 255, 255, 0.7) 40%, 
      transparent 70%
    );
  }

  .hero__container {
    position: relative;
    z-index: 10;
    max-width: 1440px;
    margin: 0 auto;
    padding: 6rem 1.5rem;
  }

  @media (min-width: 768px) {
    .hero__container {
      padding: 6rem 3rem;
    }
  }

  .hero__content {
    max-width: 560px;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    color: #E6A500;
    margin-bottom: 1.5rem;
  }

  .hero__badge svg {
    width: 16px;
    height: 16px;
  }

  .hero__title {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .hero__title {
      font-size: 4.5rem;
    }
  }

  .hero__description {
    font-size: 1.125rem;
    color: #4B5563;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 400px;
  }

  .hero__buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .hero__buttons {
      flex-direction: row;
    }
  }

  .text-gold-gradient {
    background: linear-gradient(135deg, #FFD700, #E6A500);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Nueva Colección"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Irradia Tu"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading highlight (gold)",
      "default": "Brillo Natural"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Descubre productos de belleza de lujo diseñados para la mujer moderna. Abraza la confianza con nuestra colección curada."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Comprar Ahora"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_secondary_text",
      "label": "Button text",
      "default": "Explorar Skincare"
    },
    {
      "type": "url",
      "id": "button_secondary_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}