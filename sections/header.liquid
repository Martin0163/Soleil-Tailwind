<header 
  id="site-header"
  class="header{% if template.name == 'index' %} header--home-transparent header--home-hero{% else %} header--internal{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="header"
  data-home-transparent="{% if template.name == 'index' %}true{% else %}false{% endif %}"
  style="
    --header-bg: {{ section.settings.header_bg }};
    --header-text: {{ section.settings.header_text_color }};
    --header-icon: {{ section.settings.header_icon_color }};
    --header-padding-y: {{ section.settings.header_padding_y }}px;
    --header-padding-x: {{ section.settings.header_padding_x }}px;
    --header-menu-align: {{ section.settings.menu_alignment }};
    --header-logo-width: {{ section.settings.logo_width }}px;
    --announcement-height: {{ section.settings.announcement_bar_height }}px;
  "
>
  <div class="header__container">
    <div class="header__top">
      <button 
        class="header__mobile-btn" 
        data-mobile-menu-open 
        aria-label="{{ 'general.accessibility.menu' | t }}"
      >
        {% render 'icon-menu' %}
      </button>

      <a href="{{ routes.root_url }}" class="header__logo">
        {%- if section.settings.logo != blank -%}
          <img 
            src="{{ section.settings.logo | image_url: width: 200 }}" 
            alt="{{ shop.name }}"
            width="{{ section.settings.logo_width }}"
            height="auto"
            loading="eager"
          >
        {%- else -%}
          <h1 class="header__logo-text">{{ section.settings.logo_text | default: shop.name }}</h1>
        {%- endif -%}
      </a>

      <div class="header__icons">
        <button class="header__icon-btn" data-search-open aria-label="{{ 'general.search.search' | t }}">
          {% render 'icon-search' %}
        </button>

        {%- if customer and section.settings.show_account -%}
          <a href="{{ routes.account_url }}" class="header__icon-btn" aria-label="{{ 'customer.account.title' | t }}">
            {% render 'icon-user' %}
          </a>
        {%- endif -%}

        {% if section.settings.show_wishlist %}
          <a href="{{ routes.account_url }}" class="header__icon-btn header__wishlist-btn" aria-label="Favoritos">
            {% render 'icon-heart' %}
          </a>
        {% endif %}
        
        {% if section.settings.show_cart %}
          <a
            href="{{ routes.cart_url }}"
            class="header__icon-btn header__cart-btn"
            aria-label="{{ 'cart.general.title' | t }}"
            data-cart-open
          >
            {% render 'icon-cart' %}
            <span class="header__cart-count" data-cart-count>{{ cart.item_count }}</span>
          </a>
        {% endif %}

        <div
          id="mini-cart"
          class="mini-cart hidden"
          data-cart-drawer
          aria-hidden="true"
        >
          <div class="mini-cart-header">
            <h4>Tu carrito</h4>
            <button type="button" class="mini-cart-close" data-cart-close aria-label="{{ 'general.accessibility.close' | t }}">×</button>
          </div>

          <div id="mini-cart-items" class="mini-cart-items" data-cart-items></div>

          <div class="mini-cart-summary">
            <span>Subtotal:</span>
            <strong id="mini-cart-subtotal" data-cart-subtotal>$0.00</strong>
          </div>

          <div class="mini-cart-footer">
            <a href="/checkout" class="btn btn--primary w-full">Proceder al pago</a>
          </div>
        </div>

        {%- if customer -%}
          <a href="{{ routes.account_url }}" class="header__login-btn">{{ 'customer.account.title' | t }}</a>
        {%- else -%}
          <a href="{{ routes.account_login_url }}" class="header__login-btn">{{ section.settings.login_text | default: 'Iniciar Sesión' }}</a>
        {%- endif -%}
      </div>
    </div>

    <nav class="header__nav">
      {%- unless template.name == 'index' -%}
        <a href="{{ routes.root_url }}" class="header__home-link">
          {% render 'icon-home' %}
        </a>
      {%- endunless -%}

      {%- for link in linklists[section.settings.menu].links -%}
        {%- if link.title == 'Inicio' or link.title == 'INICIO' or link.title == 'Home' -%}
          {%- continue -%}
        {%- endif -%}

        {%- if link.links != blank -%}
          <div class="header__nav-item{% if link.links.first.links != blank %} header__nav-item--mega{% endif %}">
            <a href="{{ link.url }}" class="header__nav-link{% if link.active %} is-active{% endif %}">
              {{ link.title }}
              {% render 'icon-chevron-down' %}
            </a>
            
            {%- if link.links.first.links != blank -%}
              <div class="header__mega-menu">
                {%- for childlink in link.links -%}
                  <div class="header__mega-column">
                    <h4 class="header__mega-title">{{ childlink.title }}</h4>
                    {%- for grandchildlink in childlink.links -%}
                      <a href="{{ grandchildlink.url }}" class="header__mega-link">
                        {{ grandchildlink.title }}
                      </a>
                    {%- endfor -%}
                  </div>
                {%- endfor -%}
              </div>
            {%- else -%}
              <div class="header__dropdown">
                {%- for childlink in link.links -%}
                  <a href="{{ childlink.url }}" class="header__dropdown-link">
                    {{ childlink.title }}
                  </a>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- else -%}
          <a href="{{ link.url }}"
            class="header__nav-link{% if link.title == 'Nuevo' or link.title == 'New' %} header__nav-link--highlight{% endif %}{% if link.active %} is-active{% endif %}"
          >
            {{ link.title }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </nav>
  </div>
</header>

<div class="header-spacer{% if template.name == 'index' %} header-spacer--overlay{% endif %}"></div>

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "header-section",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Texto del logo (si no hay imagen)",
      "default": "Soleil Beauty Shop"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Ancho del logo",
      "min": 80,
      "max": 250,
      "step": 10,
      "default": 150
    },
    {
      "type": "header",
      "content": "Menú"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menú principal",
      "default": "main-menu"
    },
    {
      "type": "select",
      "id": "menu_alignment",
      "label": "Alineación del menú",
      "options": [
        { "value": "left", "label": "Izquierda" },
        { "value": "center", "label": "Centro" },
        { "value": "right", "label": "Derecha" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Estilos del Header"
    },
    {
      "type": "color",
      "id": "header_bg",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "header_text_color",
      "label": "Color del texto",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "header_icon_color",
      "label": "Color de íconos",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "header_padding_y",
      "label": "Padding vertical",
      "min": 4,
      "max": 40,
      "step": 2,
      "default": 16
    },
    {
      "type": "range",
      "id": "header_padding_x",
      "label": "Padding horizontal",
      "min": 4,
      "max": 40,
      "step": 2,
      "default": 16
    },
    {
      "type": "header",
      "content": "Íconos"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Mostrar icono de búsqueda",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Mostrar icono de favoritos",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Mostrar icono de cuenta",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "Mostrar icono del carrito",
      "default": true
    },
    {
      "type": "header",
      "content": "Comportamiento"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Header sticky",
      "default": true
    },
    {
      "type": "range",
      "id": "announcement_bar_height",
      "label": "Altura del announcement bar (px)",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 36
    }
  ]
}
{% endschema %}
