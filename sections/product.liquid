{% comment %}
  PRODUCT PAGE – SOLEIL BEAUTY SHOP
  Tema personalizado desde cero
{% endcomment %}

<section class="product-page shopify-section">
  <div class="container product-page__wrapper">

    <!-- ============================
         GALERÍA DE IMÁGENES
    ============================= -->
    <div class="product-page__gallery">

      <!-- Miniaturas -->
      <div class="product-thumbs">
        {% for media in product.media %}
          <img 
            src="{{ media | image_url: width: 200 }}"
            class="thumb-img"
            data-full="{{ media | image_url: width: 1200 }}"
          >
        {% endfor %}
      </div>

      <!-- Imagen principal -->
      <div class="product-main-image">
        {% assign first_image = product.media.first %}
        <img 
          id="main-product-image"
          src="{{ first_image | image_url: width: 1200 }}"
        >
      </div>

    </div>

    <!-- ============================
         INFORMACIÓN DEL PRODUCTO
    ============================= -->
    <div class="product-page__info">

      <!-- Título -->
      <h1 class="product-title">
        {{ product.title }}
      </h1>

      <!-- Precio -->
      <div class="product-price">
        {{ product.selected_or_first_available_variant.price | money }}
      </div>

      <!-- ============================
           FORMULARIO DE COMPRA
      ============================= -->
      <div class="product-form">
        {% form 'product', product %}

          {% assign current_variant = product.selected_or_first_available_variant %}

          <!-- Selector de variantes -->
          {% if product.variants.size > 1 %}
            <label class="product-option-label">Selecciona una opción</label>
            <select name="id" id="variant-select" class="product-select">
              {% for variant in product.variants %}
                <option 
                  value="{{ variant.id }}"
                  data-image="{{ variant.featured_image | image_url: width: 1200 }}"
                  {% if variant == current_variant %}selected{% endif %}
                >
                  {{ variant.title }}
                </option>
              {% endfor %}
            </select>
          {% else %}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {% endif %}

          <!-- Cantidad -->
          <div class="product-qty">
            <label for="quantity">Cantidad</label>
            <input
              id="quantity"
              type="number"
              name="quantity"
              min="1"
              value="1"
              class="product-qty-input"
            >
          </div>

          <!-- Botón de compra -->
          <button type="submit" class="btn btn--primary product-add-btn">
            Agregar al carrito
          </button>

          {{ form | payment_button }}

        {% endform %}
      </div>

      <!-- ============================
           TABS
      ============================= -->
      <div class="product-tabs">
        <button class="tab-btn active" data-tab="tab-details">Detalles</button>
        <button class="tab-btn" data-tab="tab-reviews">Reseñas</button>
        <button class="tab-btn" data-tab="tab-store">Tienda</button>
        <button class="tab-btn" data-tab="tab-related">Te podría interesar</button>
      </div>

      <div class="tab-content active" id="tab-details">
        {% render 'product-details-table', product: product %}
      </div>

      <div class="tab-content" id="tab-reviews">
        {% render 'product-reviews', product: product %}
      </div>

      <div class="tab-content" id="tab-store">
        <p>Envíos desde Campeche, México.<br>Atención personalizada.</p>
      </div>

      <div class="tab-content" id="tab-related">
        {% render 'product-related', product: product %}
      </div>

    </div>
  </div>

  <!-- ============================
       JAVASCRIPT
  ============================= -->
  <script>
  /* Miniaturas → cambiar imagen principal */
  document.querySelectorAll('.thumb-img').forEach(img => {
    img.addEventListener('click', () => {
      document.getElementById('main-product-image').src = img.dataset.full;
    });
  });

  /* Variantes → cambiar imagen principal */
  const variantSelect = document.getElementById('variant-select');
  if (variantSelect) {
    variantSelect.addEventListener('change', () => {
      const selected = variantSelect.options[variantSelect.selectedIndex];
      const img = selected.dataset.image;
      if (img) {
        document.getElementById('main-product-image').src = img;
      }
    });
  }

  /* Tabs */
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));

      btn.classList.add('active');
      document.getElementById(btn.dataset.tab).classList.add('active');
    });
  });
  </script>

  <script>
document.querySelector('.product-form form').addEventListener('submit', function(e) {
  e.preventDefault(); // Evita redirección

  const formData = new FormData(this);

  fetch('/cart/add.js', {
    method: 'POST',
    body: formData
  })
  .then(response => response.json())
  .then(data => {
    console.log('Producto agregado:', data);

    // Aquí puedes mostrar un mensaje, popup o animación
    alert('Producto agregado al carrito');
  })
  .catch(error => {
    console.error('Error al agregar al carrito:', error);
  });
});
</script>

</section>

<style>
/* ============================================
   PRODUCT PAGE – ESTILOS SOLEIL
============================================ */

/* Layout general */
.product-page__wrapper {
  display: grid;
  gap: 3rem;
  padding-top: 4rem;
  padding-bottom: 4rem;
}

@media (min-width: 1024px) {
  .product-page__wrapper {
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }
}

/* Galería */
.product-page__gallery {
  display: flex;
  gap: 1.5rem;
}

.product-thumbs {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  width: 90px;
}

.thumb-img {
  width: 100%;
  border-radius: 6px;
  cursor: pointer;
  border: 1px solid #eee;
  transition: 0.2s;
}

.thumb-img:hover {
  border-color: black;
}

.product-main-image img {
  width: 100%;
  border-radius: 10px;
  box-shadow: var(--shadow-md);
}

/* Info */
.product-title {
  font-family: var(--font-heading);
  font-size: 2rem;
  margin-bottom: 1rem;
}

.product-price {
  font-size: 1.5rem;
  font-weight: 600;
  margin-bottom: 2rem;
}

/* Formulario */
.product-select,
.product-qty-input {
  width: 100%;
  padding: 1rem;
  border: 1px solid rgba(0,0,0,0.2);
  margin-bottom: 1.5rem;
  font-size: 1rem;
  border-radius: 4px;
}

.product-option-label {
  font-weight: 600;
  margin-bottom: 0.5rem;
  display: block;
}

.product-qty {
  margin-bottom: 1.5rem;
}

.product-add-btn {
  width: 100%;
  margin-bottom: 1rem;
}

/* Tabs */
.product-tabs {
  display: flex;
  justify-content: center;
  gap: 2rem;
  margin-top: 3rem;
  border-bottom: 1px solid #eee;
}

.tab-btn {
  padding: 0.8rem 1.2rem;
  background: none;
  border: none;
  cursor: pointer;
  font-weight: 600;
  color: #666;
}

.tab-btn.active {
  color: black;
  border-bottom: 2px solid black;
}

.tab-content {
  display: none;
  padding-top: 2rem;
}

.tab-content.active {
  display: block;
}

/* Tabla de detalles */
.details-table {
  width: 100%;
  border-collapse: collapse;
}

.details-table td {
  padding: 0.8rem 0;
  border-bottom: 1px solid #eee;
}
</style>

{% schema %}
{
  "name": "Product Page",
  "settings": []
}
{% endschema %}