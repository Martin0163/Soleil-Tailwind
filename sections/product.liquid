{% comment %}
  PDP modular Tailwind-first
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign first_media = product.featured_media | default: product.media.first -%}

<section
  class="shopify-section"
  data-product-section
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
>
  <div class="container py-12 lg:py-16">
    <div class="grid gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="flex gap-4" data-product-gallery>
        <div class="hidden w-20 shrink-0 md:flex md:flex-col md:gap-3">
          {% for media in product.media %}
            {% if media.media_type == 'image' %}
              <button
                type="button"
                class="overflow-hidden rounded-md border border-gray-200 transition hover:border-black focus:outline-none focus:ring-2 focus:ring-black {% if forloop.first %}ring-2 ring-black{% endif %}"
                data-product-thumb
                data-media-url="{{ media | image_url: width: 1400 }}"
                aria-label="{{ product.title | escape }} - imagen {{ forloop.index }}"
              >
                <img
                  src="{{ media | image_url: width: 160 }}"
                  alt="{{ product.title | escape }} - miniatura {{ forloop.index }}"
                  class="h-20 w-full object-cover"
                  loading="lazy"
                  width="80"
                  height="80"
                >
              </button>
            {% endif %}
          {% endfor %}
        </div>

        <div class="w-full overflow-hidden rounded-xl border border-gray-100 bg-white shadow-sm">
          {% if first_media %}
            <img
              data-product-main-image
              src="{{ first_media | image_url: width: 1400 }}"
              alt="{{ product.title | escape }}"
              class="h-full w-full object-cover"
              loading="eager"
              width="900"
              height="900"
            >
          {% else %}
            <div class="flex min-h-[420px] items-center justify-center text-sm text-gray-500">
              {{ 'products.product.no_media' | t | default: 'Sin imagen disponible' }}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="space-y-8">
        <div class="space-y-3">
          <h1 class="font-heading text-3xl font-semibold tracking-tight md:text-4xl">{{ product.title }}</h1>
          <p class="text-2xl font-semibold text-black" data-product-price>
            {{ current_variant.price | money }}
          </p>
        </div>

        <div>
          {% form 'product', product, class: 'space-y-5', data-product-form: '' %}
            {% if product.variants.size > 1 %}
              <div class="space-y-2">
                <label for="variant-select-{{ section.id }}" class="block text-sm font-medium text-gray-800">
                  Selecciona una opción
                </label>
                <select
                  id="variant-select-{{ section.id }}"
                  name="id"
                  class="w-full rounded-md border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 focus:border-black focus:outline-none focus:ring-1 focus:ring-black"
                  data-product-variant-select
                >
                  {% for variant in product.variants %}
                    <option
                      value="{{ variant.id }}"
                      data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 1400 }}{% elsif first_media %}{{ first_media | image_url: width: 1400 }}{% endif %}"
                      data-price="{{ variant.price | money }}"
                      {% if variant == current_variant %}selected{% endif %}
                    >
                      {{ variant.title }}
                    </option>
                  {% endfor %}
                </select>
              </div>
            {% else %}
              <input type="hidden" name="id" value="{{ current_variant.id }}">
            {% endif %}

            <div class="space-y-2">
              <label for="quantity-{{ section.id }}" class="block text-sm font-medium text-gray-800">
                Cantidad
              </label>
              <input
                id="quantity-{{ section.id }}"
                type="number"
                name="quantity"
                min="1"
                value="1"
                class="w-full rounded-md border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 focus:border-black focus:outline-none focus:ring-1 focus:ring-black"
                data-product-quantity
              >
            </div>

            <button
              type="submit"
              class="inline-flex w-full items-center justify-center rounded-md bg-black px-6 py-3 text-sm font-semibold uppercase tracking-wide text-white transition hover:bg-gold hover:text-black"
              data-product-submit
            >
              Agregar al carrito
            </button>

            {{ form | payment_button }}
          {% endform %}
        </div>

        <div class="space-y-4" data-product-tabs>
          <div class="flex flex-wrap gap-3 border-b border-gray-200 pb-2">
            <button type="button" class="rounded-full border border-black bg-black px-4 py-2 text-xs font-semibold uppercase tracking-wide text-white" data-tab-trigger="details" aria-selected="true">Detalles</button>
            <button type="button" class="rounded-full border border-gray-300 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-gray-700" data-tab-trigger="reviews" aria-selected="false">Reseñas</button>
            <button type="button" class="rounded-full border border-gray-300 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-gray-700" data-tab-trigger="store" aria-selected="false">Tienda</button>
            <button type="button" class="rounded-full border border-gray-300 px-4 py-2 text-xs font-semibold uppercase tracking-wide text-gray-700" data-tab-trigger="related" aria-selected="false">Te podría interesar</button>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12 space-y-10 lg:mt-16">
      <section id="details" data-product-anchor-section="details" class="product-anchor-section rounded-lg border border-gray-100 bg-white p-6 shadow-sm">
        <h2 class="mb-4 font-heading text-2xl font-semibold">Detalles</h2>
        {% render 'product-details-table', product: product %}
      </section>

      <section id="reviews" data-product-anchor-section="reviews" class="product-anchor-section rounded-lg border border-gray-100 bg-white p-6 shadow-sm">
        <h2 class="mb-4 font-heading text-2xl font-semibold">Reseñas</h2>
        {% render 'product-reviews', product: product %}
      </section>

      <section id="store" data-product-anchor-section="store" class="product-anchor-section rounded-lg border border-gray-100 bg-white p-6 shadow-sm">
        <h2 class="mb-4 font-heading text-2xl font-semibold">Tienda</h2>
        <p class="text-sm leading-relaxed text-gray-700">
          Envíos desde Campeche, México.<br>Atención personalizada.
        </p>
      </section>

      <section id="related" data-product-anchor-section="related" class="product-anchor-section rounded-lg border border-gray-100 bg-white p-6 shadow-sm">
        <h2 class="mb-4 font-heading text-2xl font-semibold">Te podría interesar</h2>
        {% render 'product-related', product: product %}
      </section>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Page",
  "settings": []
}
{% endschema %}
