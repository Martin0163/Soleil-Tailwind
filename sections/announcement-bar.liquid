{%- if section.settings.show_announcement_bar -%}
<div
  class="announcement-bar"
  data-section-id="{{ section.id }}"
  data-section-type="announcement-bar"
  data-announcement-direction="{{ section.settings.marquee_direction }}"
  style="
    --announcement-bg: {{ section.settings.background_color }};
    --announcement-text: {{ section.settings.text_color }};
    --announcement-separator: {{ section.settings.separator_color }};
    --announcement-height: {{ section.settings.bar_height }}px;
    --announcement-speed: {{ section.settings.animation_speed }}s;
    --announcement-font-size: {{ section.settings.font_size }}px;
    --announcement-font-family: {{ section.settings.font_family }};
  "
>
  <div class="announcement-bar__marquee" aria-label="Announcement messages">
    <div class="announcement-bar__track">
      {%- for i in (1..2) -%}
        {%- for block in section.blocks -%}
          <span class="announcement-bar__item" {{ block.shopify_attributes }}>
            <span class="announcement-bar__text">{{ block.settings.text }}</span>
            <span class="announcement-bar__separator">{{ section.settings.separator_char }}</span>
          </span>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    <div class="announcement-bar__track" aria-hidden="true">
      {%- for i in (1..2) -%}
        {%- for block in section.blocks -%}
          <span class="announcement-bar__item">
            <span class="announcement-bar__text">{{ block.settings.text }}</span>
            <span class="announcement-bar__separator">{{ section.settings.separator_char }}</span>
          </span>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement_bar",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator color",
      "default": "#FFD700"
    },
    {
      "type": "text",
      "id": "separator_char",
      "label": "Separator character",
      "default": "✦"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font family",
      "options": [
        { "value": "var(--font-heading)", "label": "Heading font" },
        { "value": "var(--font-body)", "label": "Body font" },
        { "value": "Arial, sans-serif", "label": "Arial" },
        { "value": "'Helvetica Neue', sans-serif", "label": "Helvetica Neue" }
      ],
      "default": "var(--font-heading)"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size (px)",
      "min": 10,
      "max": 18,
      "step": 1,
      "default": 11
    },
    {
      "type": "range",
      "id": "bar_height",
      "label": "Bar height (px)",
      "min": 28,
      "max": 56,
      "step": 2,
      "default": 36
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Animation speed (seconds)",
      "min": 12,
      "max": 90,
      "step": 2,
      "default": 30,
      "info": "Lower = faster"
    },
    {
      "type": "select",
      "id": "marquee_direction",
      "label": "Marquee direction",
      "options": [
        { "value": "left", "label": "Right to left" },
        { "value": "right", "label": "Left to right" }
      ],
      "default": "left"
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Bienvenida a Soleil Beauty Shop, disfruta de nuestras mejores ofertas, envíos gratis a partir de 500 pesos, promociones cada mes"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "settings": {},
      "blocks": [
        {
          "type": "message",
          "settings": {
            "text": "Bienvenida a Soleil Beauty Shop, disfruta de nuestras mejores ofertas"
          }
        },
        {
          "type": "message",
          "settings": {
            "text": "Envíos gratis a partir de 500 pesos"
          }
        },
        {
          "type": "message",
          "settings": {
            "text": "Promociones cada mes"
          }
        }
      ]
    }
  ]
}
{% endschema %}
