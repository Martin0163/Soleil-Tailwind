<section 
  class="categories"
  data-section-id="{{ section.id }}"
  data-section-type="categories"
>
  <div class="categories__container">
    <div class="categories__header" data-animate="fadeInUp">
      <h2 class="categories__title">{{ section.settings.heading }}</h2>
      <p class="categories__subtitle">{{ section.settings.subheading }}</p>
    </div>

    <div class="categories__grid">
      {%- for block in section.blocks -%}
        {%- assign collection = collections[block.settings.collection] -%}
        {% render 'category-card', 
          block: block,
          collection: collection,
          index: forloop.index
        %}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .categories {
    padding: 6rem 0;
    background-color: #FAF9F7;
  }

  @media (min-width: 768px) {
    .categories {
      padding: 8rem 0;
    }
  }

  .categories__container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 768px) {
    .categories__container {
      padding: 0 3rem;
    }
  }

  .categories__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .categories__title {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    .categories__title {
      font-size: 3rem;
    }
  }

  .categories__subtitle {
    color: #4B5563;
    margin: 0;
  }

  .categories__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .categories__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
  }
</style>

{% schema %}
{
  "name": "Categories",
  "tag": "section",
  "class": "categories-section",

  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Compra por Categoría"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Encuentra tu rutina de belleza perfecta"
    }
  ],

  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Categoría" },
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "select",
          "id": "size",
          "label": "Size",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "large", "label": "Large (2x2)" }
          ],
          "default": "small"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Categories",
      "blocks": [
        { "type": "category", "settings": { "title": "Cuidado de Piel", "size": "large" } },
        { "type": "category", "settings": { "title": "Maquillaje", "size": "small" } },
        { "type": "category", "settings": { "title": "Cabello", "size": "small" } },
        { "type": "category", "settings": { "title": "Fragancias", "size": "small" } }
      ]
    }
  ]
}
{% endschema %}