{%- comment -%}
  Mobile Menu Drawer
{%- endcomment -%}

<div class="mobile-menu" id="mobile-menu" data-mobile-menu>
  <div class="mobile-menu__header">
    <h2 class="mobile-menu__logo">{{ shop.name }}</h2>
    <button class="mobile-menu__close" data-mobile-menu-close aria-label="{{ 'general.accessibility.close' | t }}">
      {% render 'icon-close' %}
    </button>
  </div>
  
  <nav class="mobile-menu__nav">
    {%- for link in linklists.main-menu.links -%}
      {%- if link.links != blank -%}
        <div class="mobile-menu__item mobile-menu__item--has-children">
          <button class="mobile-menu__link mobile-menu__link--parent" data-mobile-submenu-toggle>
            {{ link.title }}
            {% render 'icon-chevron-down' %}
          </button>
          <div class="mobile-menu__submenu">
            <a href="{{ link.url }}" class="mobile-menu__sublink mobile-menu__sublink--all">
              Ver todo {{ link.title }}
            </a>
            {%- for childlink in link.links -%}
              {%- if childlink.links != blank -%}
                <div class="mobile-menu__subgroup">
                  <span class="mobile-menu__subgroup-title">{{ childlink.title }}</span>
                  {%- for grandchildlink in childlink.links -%}
                    <a href="{{ grandchildlink.url }}" class="mobile-menu__sublink">
                      {{ grandchildlink.title }}
                    </a>
                  {%- endfor -%}
                </div>
              {%- else -%}
                <a href="{{ childlink.url }}" class="mobile-menu__sublink">
                  {{ childlink.title }}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- else -%}
        <a href="{{ link.url }}" class="mobile-menu__link">
          {{ link.title }}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </nav>
  
  <div class="mobile-menu__footer">
    {%- if customer -%}
      <a href="{{ routes.account_url }}" class="mobile-menu__footer-link">
        {% render 'icon-user' %}
        {{ 'customer.account.title' | t }}
      </a>
    {%- else -%}
      <a href="{{ routes.account_login_url }}" class="mobile-menu__footer-link">
        {% render 'icon-user' %}
        {{ 'customer.login.title' | t | default: 'Iniciar Sesión' }}
      </a>
    {%- endif -%}
  </div>
</div>

<div class="mobile-menu__overlay" data-mobile-menu-overlay></div>

<style>
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 100%;
    max-width: 400px;
    z-index: 100;
    background-color: #fff;
    transform: translateX(-100%);
    transition: transform 0.3s ease-in-out;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .mobile-menu.is-open {
    transform: translateX(0);
  }

  .mobile-menu__overlay {
    position: fixed;
    inset: 0;
    z-index: 99;
    background-color: rgba(0, 0, 0, 0.5);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .mobile-menu__overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }

  .mobile-menu__logo {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
  }

  .mobile-menu__close {
    padding: 8px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .mobile-menu__close svg {
    width: 24px;
    height: 24px;
  }

  .mobile-menu__nav {
    flex: 1;
    padding: 1.5rem;
  }

  .mobile-menu__item {
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }

  .mobile-menu__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1rem 0;
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    color: #000;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }

  .mobile-menu__link svg {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .mobile-menu__item--has-children.is-open .mobile-menu__link svg {
    transform: rotate(180deg);
  }

  .mobile-menu__submenu {
    display: none;
    padding-bottom: 1rem;
  }

  .mobile-menu__item--has-children.is-open .mobile-menu__submenu {
    display: block;
  }

  .mobile-menu__sublink {
    display: block;
    padding: 0.5rem 0 0.5rem 1rem;
    font-size: 0.875rem;
    color: #4B5563;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .mobile-menu__sublink:hover {
    color: #000;
  }

  .mobile-menu__sublink--all {
    font-weight: 600;
    color: #E6A500;
  }

  .mobile-menu__subgroup {
    margin-top: 1rem;
  }

  .mobile-menu__subgroup-title {
    display: block;
    padding: 0.5rem 0 0.5rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #E6A500;
  }

  .mobile-menu__footer {
    padding: 1.5rem;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
  }

  .mobile-menu__footer-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #000;
    text-decoration: none;
  }

  .mobile-menu__footer-link svg {
    width: 20px;
    height: 20px;
  }

  @media (min-width: 1024px) {
    .mobile-menu,
    .mobile-menu__overlay {
      display: none;
    }
  }
</style>